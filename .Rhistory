ggsave("figs/plot_standardized_prediction_error.pdf", p2, width = 10, height = 7)
ggsave("figs/plot_human_brain_mosaicism.pdf", p3, width = 10, height = 7)
ggsave("figs/plot_pagel_lambda_profile.pdf", p4, width = 10, height = 7)
