)
names(print_ready_df) <- rep("", ncol(print_ready_df))
write.table(print_ready_df, here("output", "print_ready_table.tsv"),
sep = "\t", quote = FALSE, row.names = FALSE, col.names = FALSE)
write_xlsx(print_ready_df, here("output", "print_ready_table.xlsx"), col_names = FALSE)
## -------------------------
## TO REPORT: Correlation analysis between rCMRGlc and prediction error (Diff.pre) across structures
## -------------------------
diff_cols <- c(
"Brownian (BM)__Diff.min",
"Brownian (BM)__Diff.pre",
"Brownian (BM)__Diff.max",
"Pagel's Lambda (ML)__Diff.min",
"Pagel's Lambda (ML)__Diff.pre",
"Pagel's Lambda (ML)__Diff.max"
)
# keep needed columns + coerce to numeric
cor_df <- tbl_body %>%
transmute(
Structure,
rCMRGlc = parse_number(as.character(rCMRGlc)),
across(all_of(diff_cols), ~ as.numeric(as.character(.x)))
)
# one correlation per Diff column (across Structure rows)
cor_pearson <- map_dfr(diff_cols, function(col) {
x <- cor_df[[col]]
y <- cor_df$rCMRGlc
ok <- complete.cases(x, y)
ct <- cor.test(x[ok], y[ok], method = "pearson")
tibble(
Diff_column = col,
n = sum(ok),
r = unname(ct$estimate),
p_value = ct$p.value,
ci_low = ct$conf.int[1],
ci_high = ct$conf.int[2]
)
})
cor_spearman <- map_dfr(diff_cols, function(col) {
x <- cor_df[[col]]
y <- cor_df$rCMRGlc
ok <- complete.cases(x, y)
ct <- cor.test(x[ok], y[ok], method = "spearman")
tibble(
Diff_column = col,
n = sum(ok),
rho = unname(ct$estimate),
p_value = ct$p.value,
ci_low = ct$conf.int[1],
ci_high = ct$conf.int[2]
)
})
# Correlation between rCMRGlc and Prediction Error (BM)
plot(cor_df$rCMRGlc, cor_df$`Brownian (BM)__Diff.pre`, xlab = "rCMRGlc", ylab = "Diff.pre (BM)", main = "Correlation between rCMRGlc and Prediction Error (BM)")
text(cor_df$rCMRGlc, cor_df$`Brownian (BM)__Diff.pre`, labels = cor_df$Structure, pos = 4, cex = 0.7)
