mouse_gas <- read.csv("S:/BIOL2006/Data files/mouse_gas.txt")
View(mouse_gas)
#### P1. Taking a random factor ('Assistant') into account ####
View(mouse_gas)                   # have a look at the data
attach(mouse_gas) # make 'mouse_gas' the default data set
anova(lm(Y~Dose))		# assess the effect of dose upon metabolic rate (Y)
anova(lm(Y~Dose+Assistant))	# test 'Assistant' (wrongly) as a fixed effect
library(lmerTest) 			# load the 'lmerTest' package into your sesssion
install.packages("lmerTest")
library(lmerTest) 			# load the 'lmerTest' package into your sesssion
# use the 'lmer' program to treat 'Assistant' correctly as a random effect
anova(lmer( Y ~ Dose + (1 | Assistant) )) # a "mixed-effect" regression model
#### P2. Interaction of fixed and random explanatory variables ####
# Model 'Dose:Assistant' interaction treating 'Assistant' (wrongly) as a fixed effect
fit1 <- lm( Y ~ Dose * Assistant , data=mouse_gas)
plot(fit1) # check the diagnostics
anova(fit1)	# inspect the test-statistic for the effect of 'Dose'
summary(fit1)	# look at the regression coefficients
# Model 'Dose:Assistant' interaction as a random effect.
fit2 <- lmer(Y ~ Dose + (1|Assistant)+ ( 1 | Dose:Assistant ) , data=mouse_gas)
plot(fit2) # check the "constant residual variance" assumption
qqnorm(residuals(fit2)) # check the "gaussian residuals" assumption
anova(fit2) # assess the effect of 'Dose'
summary(fit2)	# look at the regression coefficients
#### P3. Random intercepts and random slopes ####
# add "Day" to the model, as a random intercept explanatory variable
fit3 <- lmer( Y ~ Dose + (1 | Assistant) + ( 1 | Dose:Assistant ) + (1|Day), data=mouse_gas)
anova(fit3) # inspect the test-statistic for the effect of 'Dose'
summary(fit3) # look at regression coefficients and components of variance
anova(fit2,fit3) # compare two models
# add a random slope effect of 'Day' to the model
fit4 <- lmer(Y ~ Dose + (Day|Assistant)+ ( 1 | Dose:Assistant ) + (1|Day), data=mouse_gas)
anova(fit4) # inspect the test-statistic for the effect of 'Dose'
anova(fit3,fit4) # compare two models
Habitat_abundance <- read.csv("S:/BIOL2006/Data files/Habitat_abundance.txt")
View(Habitat_abundance)
#### P4. Two-way nested ANOVA ####
attach(Habitat_abundance) # make "Habitat abundance" the default data set
Habitat_list <- unique(Habitat) # list the habitats
Site_list <- unique(Site) # list the sites
Habitat_index <- match(Habitat_abundance$Habitat,Habitat_list) # recode habitats as numbers
Site_index <- match(Habitat_abundance$Site,Site_list) # recode sites as numbers
plot(Habitat_index,Abundance,type="n",xlab="",xaxt="n") # create an empty graph
points(Habitat_index,Abundance,col=Site_index,pch=Site_index) # colour/shape coded points
axis(side=1,at=1:5,labels=Habitat_list) # label the horizontal axis
legend(4.3,25,legend=Site_list,col=unique(Site_index),pch=unique(Site_index),xpd=T,cex=0.8)
# treat "Site" as though it were a fixed effect
m1 <- lm(Abundance ~ Habitat + Site, data = Habitat_abundance) # full model
plot(m1) # check the diagnostics
m2 <- lm(sqrt(Abundance) ~ Habitat + Site, data = Habitat_abundance) # try "square root"
plot(m2) # check the diagnostics
anova(m2) # look at test-statistics
summary(m2) # look at regression coefficients
# treat "Site" as random and nested within "Habitat"
m3 <- lmer(sqrt(Abundance) ~ Habitat + (1|Site), data = Habitat_abundance)
anova(m3) # look at test-statistics
summary(m3) # look at regression coefficients and components of variance
#### P5. Comparing "fixed model" to "mixed model" ####
# Fit a "fixed model"
fixed_model <- lm(log(Abundance+1) ~ Treatment* Rehab_Year * Rep_Year )
View(Habitat_abundance)
Ants <- read.csv("S:/BIOL2006/Data files/Ants.txt")
View(Ants)
attach(Ants)
#### P5. Comparing "fixed model" to "mixed model" ####
# Fit a "fixed model"
fixed_model <- lm(log(Abundance+1) ~ Treatment* Rehab_Year * Rep_Year )
Ants[439,] # there is missing data for Abundance in Row 439
Ants<-Ants[-439,] # remove the offending row
Ants$Abundance <- as.numeric(as.character(trimws(Ants$Abundance))) # remove the whitespaces
attach(Ants)# reattach Ants
#### P5. Comparing "fixed model" to "mixed model" ####
# Fit a "fixed model"
fixed_model <- lm(log(Abundance+1) ~ Treatment* Rehab_Year * Rep_Year )
# Fit a "mixed model" to the same data
mixed_model <- lmer(log(Abundance+1) ~ Treatment * Rehab_Year * Rep_Year + (1|Site) )
# compare test statistics across the two models
anova(fixed_model) ; anova(mixed_model)
# compare regression coefficients across the two models
summary(fixed_model)$coefficients
summary(mixed_model)$coefficients
# compare residual variance across the two models
summary(fixed_model)$sigma^2
summary(mixed_model)$sigma^2
#### P6. Balanced experimental design ####
Y <-           c(11.4, 6.3, 5.5, 9.5, 2.4, 3.3, 4.4, 3.6, 5.2, 1.1) # response variable
Altitude <-    c("Hi","Hi","Hi","Hi","Hi","Lo","Lo","Lo","Lo","Lo") # 1st explanatory variable
Temperature <- c("L" , "L", "L", "L", "H","H" ,"H" ,"H" ,"H" ,"L") # 2nd explanatory variable
AltitudeStudy <- cbind.data.frame(Y,Altitude,Temperature) # assemble the data
table(AltitudeStudy$Altitude,AltitudeStudy$Temperature) # show the sample sizes
