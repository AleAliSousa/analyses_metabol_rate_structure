if (is.null(x) || length(x) == 0) y else x
}
flatten_allen_node <- function(node,
parent_id = NA_integer_,
parent_name = NA_character_,
parent_acronym = NA_character_,
name_path = character(),
acronym_path = character(),
depth = 0L) {
